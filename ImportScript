function importOCAP(forceReimport = false) {
  const parentFolder = DriveApp.getFoldersByName("Kill Tracker").next();
  const folders = parentFolder.getFolders();
  let inputFolder;
  let archiveFolder;
  while (folders.hasNext()) {
    const f = folders.next();
    if (f.getName() === "OCAP_Logs") inputFolder = f;
    if (f.getName() === "OCAP_Logs_Archive") archiveFolder = f;
  }
  if (!inputFolder || !archiveFolder) {
    throw new Error("Folders OCAP_Logs or OCAP_Logs_Archive not found");
  }
  const files = inputFolder.getFiles();
  if (!files.hasNext()) {
    Logger.log("No new files found.");
    return;
  }
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let statsSheet = ss.getSheetByName("player_stats");
  if (!statsSheet) {
    statsSheet = ss.insertSheet("player_stats");
  }
  // Column schema
  const header = [
    // Mission info
    "Source File", "Mission", "World",
    // Player info
    "Username", "Side", "Group", "Role",
    // Infantry (on-foot) stats
    "Kills (On Foot)", "Deaths (On Foot)", "K/D (On Foot)",
    "Teamkills (On Foot)", "Shots (On Foot)", "Hits Taken (On Foot)",
    "Shots/Kill (On Foot)", "Avg Kill Dist On Foot (m)", "Longest Kill On Foot (m)",
    // Vehicle stats
    "Kills (In Vehicle)", "Deaths (In Vehicle)", "K/D (In Vehicle)",
    "Teamkills (In Vehicle)", "Vehicle Kills (On Foot)", "Vehicle Kills (In Vehicle)",
    "Shots (In Vehicle)", "Hits Taken (In Vehicle)",
    "Shots/Kill (In Vehicle)", "Avg Kill Dist In Vehicle (m)", "Longest Kill In Vehicle (m)",
    // Weapon stats
    "Top Weapon", "Weapon Kills (JSON)",
    // Misc
    "Suicides",
    "Time Played (s)"
  ];
  if (statsSheet.getLastRow() === 0) {
    statsSheet.getRange(1, 1, 1, header.length).setValues([header]);
  } else {
    // Migrate: append any columns that exist in header but not yet in the sheet
    const existingHeader = statsSheet.getRange(1, 1, 1, statsSheet.getLastColumn()).getValues()[0];
    header.forEach((col, i) => {
      if (!existingHeader.includes(col)) {
        statsSheet.getRange(1, i + 1).setValue(col);
        Logger.log(`Added missing header column: ${col}`);
      }
    });
  }
  // Build set of already-imported filenames from column A
  const importedFiles = new Set();
  if (statsSheet.getLastRow() > 1) {
    const existing = statsSheet.getRange(2, 1, statsSheet.getLastRow() - 1, 1).getValues();
    existing.forEach(row => {
      if (row[0]) importedFiles.add(String(row[0]).trim());
    });
    Logger.log(`Found ${importedFiles.size} already-imported filename(s) in sheet.`);
  }
  function deleteExistingRowsForFile(sheet, sourceFileName) {
    const lastRow = sheet.getLastRow();
    if (lastRow < 2) return 0;
    const values = sheet.getRange(2, 1, lastRow - 1, 1).getValues(); // column A = Source File
    const rowsToDelete = [];
    values.forEach((row, i) => {
      if (String(row[0]).trim() === sourceFileName) {
        rowsToDelete.push(i + 2); // actual sheet row number
      }
    });
    // Delete bottom-up so row indexes don't shift
    for (let i = rowsToDelete.length - 1; i >= 0; i--) {
      sheet.deleteRow(rowsToDelete[i]);
    }
    return rowsToDelete.length;
  }
  const file = files.next();
  const name = file.getName();
  if (!name.endsWith(".json.gz")) {
    Logger.log(`Skipped (not .json.gz): ${name}`);
    return;
  }
  if (importedFiles.has(name) && !forceReimport) {
    Logger.log(`Skipped (already imported): ${name}`);
    archiveFolder.addFile(file);
    inputFolder.removeFile(file);
    return;
  }
  try {
    Logger.log(`Processing: ${name}`);
    const blob = file.getBlob();
    const unzippedBlob = Utilities.ungzip(blob);
    const text = unzippedBlob.getDataAsString();
    const data = JSON.parse(text);
    // Entity lookup
    const entities = {};
    (data.entities || []).forEach(e => {
      entities[e.id] = e;
    });
    // Helper: get a player's inVehicle status at a specific frame
    // positions entry: [[x,y,z], bearing, alive, inVehicle(0/1), name, framesFired, role]
    function isInVehicleAtFrame(entity, frame) {
      if (!entity || !Array.isArray(entity.positions)) return false;
      const start = entity.startFrameNum || 0;
      const idx = frame - start;
      if (idx < 0 || idx >= entity.positions.length) return false;
      const pos = entity.positions[idx];
      return Array.isArray(pos) && pos[3] === 1;
    }
    // Zeus detection
    function isZeus(entity) {
      if (!entity) return false;
      const group = (entity.group || "").toLowerCase();
      const role = (entity.role || "").toLowerCase();
      return group === "zeus" || role.startsWith("zeus");
    }
    // Build player stats
    const players = {};
    (data.entities || []).forEach(e => {
      if (e.isPlayer === 1) {
        players[e.id] = {
          name: e.name,
          side: e.side,
          role: e.role || "",
          group: e.group || "",
          // Infantry (on-foot) stats
          killsOnFoot: 0,
          deathsOnFoot: 0,
          teamkillsOnFoot: 0,
          shotsOnFoot: 0,
          hitsTakenOnFoot: 0,
          killDistOnFoot: [],
          // Vehicle stats
          killsInVehicle: 0,
          deathsInVehicle: 0,
          teamkillsInVehicle: 0,
          vehicleKillsOnFoot: 0,
          vehicleKillsInVehicle: 0,
          shotsInVehicle: 0,
          hitsTakenInVehicle: 0,
          killDistInVehicle: [],
          // Shot frames
          framesFired: Array.isArray(e.framesFired) ? e.framesFired : [],
          // Weapon stats
          weaponKills: {},
          // Misc
          suicides: 0,
          isZeus: isZeus(e),
          timePlayed: (Array.isArray(e.positions) ? e.positions.length : 0) * (data.captureDelay || 1),
        };
      }
    });
    // Pre-compute shots fired per context
    Object.keys(players).forEach(id => {
      const p = players[id];
      const entity = entities[id];
      if (!entity) return;
      p.framesFired.forEach(entry => {
        const frame = Array.isArray(entry) ? entry[0] : entry;
        if (isInVehicleAtFrame(entity, frame)) {
          p.shotsInVehicle++;
        } else {
          p.shotsOnFoot++;
        }
      });
    });
    // Pre-build a set of "entityId:frame" for disconnect events so we can
    // detect crash/disconnect-induced self-kills and exclude them from suicides.
    // Note: "disconnected" events store the player name in event[2], not the entity ID,
    // so we need a name→id lookup to match against kill events (which use entity IDs).
    const nameToEntityId = {};
    (data.entities || []).forEach(e => {
      if (e.isPlayer === 1) nameToEntityId[e.name] = e.id;
    });
    const disconnectFrames = new Set();
    (data.events || []).forEach(event => {
      if (event[1] === "disconnected") {
        const dcId = nameToEntityId[event[2]];
        if (dcId != null) disconnectFrames.add(`${dcId}:${event[0]}`);
      }
    });
    // Process events
    (data.events || []).forEach(event => {
      const frame = event[0];
      const type = event[1];
      const victimId = event[2];
      const killerInfo = event[3];
      const distance = event[4] || 0;
      if (type === "killed") {
        const victim = entities[victimId];
        const killerId = killerInfo ? killerInfo[0] : null;
        const killer = killerId != null ? entities[killerId] : null;
        const victimType = victim ? victim.type : null;
        // Deaths
        if (victimType === "unit" && players[victimId] !== undefined) {
          const victimInVehicle = isInVehicleAtFrame(entities[victimId], frame);
          if (victimInVehicle) {
            players[victimId].deathsInVehicle++;
          } else {
            players[victimId].deathsOnFoot++;
          }
        }
        // Killer must be a known player
        if (killerId === null || players[killerId] === undefined) return;
        if (killerId === victimId) {
          // Skip if the player disconnected within 1 frame of the self-kill —
          // the game engine generates a self-kill as a side-effect of a crash/DC,
          // and the disconnect event can land on the same frame or an adjacent one.
          const isDisconnectKill =
            disconnectFrames.has(`${victimId}:${frame - 1}`) ||
            disconnectFrames.has(`${victimId}:${frame}`) ||
            disconnectFrames.has(`${victimId}:${frame + 1}`);
          if (!isDisconnectKill) {
            players[victimId].suicides++;
          }
          return;
        }
        const isSameSide = victim && killer && victim.side === killer.side;
        const killerInVehicle = isInVehicleAtFrame(entities[killerId], frame);
        if (victimType === "vehicle") {
          if (!isSameSide) {
            if (killerInVehicle) {
              players[killerId].vehicleKillsInVehicle++;
            } else {
              players[killerId].vehicleKillsOnFoot++;
            }
          }
        } else if (victimType === "unit") {
          if (isSameSide) {
            if (killerInVehicle) {
              players[killerId].teamkillsInVehicle++;
            } else {
              players[killerId].teamkillsOnFoot++;
            }
          } else {
            if (killerInVehicle) {
              players[killerId].killsInVehicle++;
              players[killerId].killDistInVehicle.push(distance);
            } else {
              players[killerId].killsOnFoot++;
              players[killerId].killDistOnFoot.push(distance);
              const weapon = (killerInfo && killerInfo[1]) ? killerInfo[1] : "Unknown";
              players[killerId].weaponKills[weapon] = (players[killerId].weaponKills[weapon] || 0) + 1;
            }
          }
        }
      }
      if (type === "hit") {
        if (players[victimId] !== undefined) {
          const victimInVehicle = isInVehicleAtFrame(entities[victimId], frame);
          if (victimInVehicle) {
            players[victimId].hitsTakenInVehicle++;
          } else {
            players[victimId].hitsTakenOnFoot++;
          }
        }
      }
    });
    const missionName = (() => {
      const base = data.missionName || "";
      const m = name.match(/(\d{4})_(\d{2})_(\d{2})/);
      if (!m) return base;
      return base + " (" + m[1] + "-" + m[2] + "-" + m[3] + ")";
    })();
    const worldName = data.worldName || "";
    const rows = [];
    Object.values(players).forEach(p => {
      // Zeus: zero all combat stats
      if (p.isZeus) {
        p.killsOnFoot = 0;
        p.deathsOnFoot = 0;
        p.teamkillsOnFoot = 0;
        p.shotsOnFoot = 0;
        p.hitsTakenOnFoot = 0;
        p.killsInVehicle = 0;
        p.deathsInVehicle = 0;
        p.teamkillsInVehicle = 0;
        p.vehicleKillsOnFoot = 0;
        p.vehicleKillsInVehicle = 0;
        p.shotsInVehicle = 0;
        p.hitsTakenInVehicle = 0;
        p.suicides = 0;
        p.killDistOnFoot = [];
        p.killDistInVehicle = [];
        p.weaponKills = {};
      }
      const kdFoot = p.deathsOnFoot > 0 ? (p.killsOnFoot / p.deathsOnFoot).toFixed(2) : p.killsOnFoot.toFixed(2);
      const kdVeh = p.deathsInVehicle > 0 ? (p.killsInVehicle / p.deathsInVehicle).toFixed(2) : p.killsInVehicle.toFixed(2);
      const spkFoot = p.killsOnFoot > 0 ? (p.shotsOnFoot / p.killsOnFoot).toFixed(1) : "";
      const spkVeh = p.killsInVehicle > 0 ? (p.shotsInVehicle / p.killsInVehicle).toFixed(1) : "";
      const avgFoot = p.killDistOnFoot.length > 0
        ? (p.killDistOnFoot.reduce((a, b) => a + b, 0) / p.killDistOnFoot.length).toFixed(0)
        : "";
      const avgVeh = p.killDistInVehicle.length > 0
        ? (p.killDistInVehicle.reduce((a, b) => a + b, 0) / p.killDistInVehicle.length).toFixed(0)
        : "";
      const lkFoot = p.killDistOnFoot.length > 0 ? Math.max(...p.killDistOnFoot) : "";
      const lkVeh = p.killDistInVehicle.length > 0 ? Math.max(...p.killDistInVehicle) : "";
      const weaponEntries = Object.entries(p.weaponKills).sort((a, b) => b[1] - a[1]);
      const topWeapon = weaponEntries.length > 0 ? weaponEntries[0][0] : "";
      const weaponJson = weaponEntries.length > 0 ? JSON.stringify(Object.fromEntries(weaponEntries)) : "";
      rows.push([
        name,
        missionName,
        worldName,
        p.name,
        p.side,
        p.group,
        p.role,
        p.killsOnFoot,
        p.deathsOnFoot,
        parseFloat(kdFoot),
        p.teamkillsOnFoot,
        p.shotsOnFoot,
        p.hitsTakenOnFoot,
        spkFoot !== "" ? parseFloat(spkFoot) : "",
        avgFoot !== "" ? parseFloat(avgFoot) : "",
        lkFoot !== "" ? lkFoot : "",
        p.killsInVehicle,
        p.deathsInVehicle,
        parseFloat(kdVeh),
        p.teamkillsInVehicle,
        p.vehicleKillsOnFoot,
        p.vehicleKillsInVehicle,
        p.shotsInVehicle,
        p.hitsTakenInVehicle,
        spkVeh !== "" ? parseFloat(spkVeh) : "",
        avgVeh !== "" ? parseFloat(avgVeh) : "",
        lkVeh !== "" ? lkVeh : "",
        topWeapon,
        weaponJson,
        p.suicides,
        Math.round(p.timePlayed),
      ]);
    });
    // Sort by on-foot kills descending
    rows.sort((a, b) => b[7] - a[7]);
    // If reimporting, remove existing rows for this source file first
    if (forceReimport || importedFiles.has(name)) {
      const deletedCount = deleteExistingRowsForFile(statsSheet, name);
      if (deletedCount > 0) {
        Logger.log(`Removed ${deletedCount} existing row(s) for ${name}`);
      }
    }
    if (rows.length > 0) {
      statsSheet.getRange(
        statsSheet.getLastRow() + 1,
        1,
        rows.length,
        rows[0].length
      ).setValues(rows);
    }
    // Archive processed file
    archiveFolder.addFile(file);
    inputFolder.removeFile(file);
    Logger.log(`Import complete: ${name} — ${rows.length} players written`);
  } catch (err) {
    Logger.log(`Error processing ${name}: ${err}`);
    throw err;
  }
}
function reimportOCAP() {
  importOCAP(true);
}